# Chat / Fabrix upstream
FABRIX_CHAT_BASE_URL=http://localhost:8000
FABRIX_API_KEY=your_chat_api_key_here
FABRIX_CLIENT_KEY=your_chat_client_key_here
FABRIX_MODEL=your_chat_model_id_here

# Embedding upstream (full endpoint URL)
EMBEDDING_URL=http://localhost:8001/v1/embeddings
EMBEDDING_MODEL=bge-m3
# Optional. Leave empty when the embedding server does not require Bearer auth or mTLS.
EMBEDDING_API_KEY=
EMBEDDING_CERT=
EMBEDDING_KEY=
EMBEDDING_VERIFY_TLS=true
EMBEDDING_TIMEOUT=60

# Rerank upstream (full endpoint URL)
RERANK_URL=http://localhost:8002/v1/rerank
RERANK_MODEL=bge-reranker
# customer_v1_rerank maps OpsG /score {text_1,text_2[]} to customer /v1/rerank {query,documents}
# legacy_score keeps the CXC/lab /score -> /score payload/response shape.
RERANK_UPSTREAM_STYLE=customer_v1_rerank
# Optional. Leave empty when the rerank server does not require Bearer auth or mTLS.
RERANK_API_KEY=
RERANK_CERT=
RERANK_KEY=
RERANK_VERIFY_TLS=true
RERANK_TIMEOUT=60